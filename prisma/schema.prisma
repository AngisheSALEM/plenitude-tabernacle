generator client {
  provider = "prisma-client-js"
  output   = "../generated/client"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  MEMBRE
  PREDICATEUR
}

model User {
  id            String    @id @default(cuid())
  firstName     String
  lastName      String
  email         String    @unique
  password      String?
  phone         String?
  address       String?
  birthDate     DateTime?
  bio           String?
  avatar        String?
  role          Role      @default(MEMBRE)
  joinDate      DateTime  @default(now())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts          Account[]
  sessions          Session[]
  favoriteVideos    FavoriteVideo[]
  favoriteAudios    FavoriteAudio[]
  favoriteCantiques FavoriteCantique[]
  sermons           Sermon[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Video {
  id          String   @id @default(cuid())
  title       String
  description String?
  speaker     String
  date        DateTime @default(now())
  views       Int      @default(0)
  duration    String?
  thumbnail   String?
  youtubeUrl  String?  @unique
  isFeatured  Boolean  @default(false)
  category    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  favorites FavoriteVideo[]

  @@map("videos")
}

model Audio {
  id          String   @id @default(cuid())
  title       String
  description String?
  speaker     String
  date        DateTime @default(now())
  plays       Int      @default(0)
  duration    String?
  fileUrl     String?
  category    String
  isFeatured  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  favorites FavoriteAudio[]

  @@map("audios")
}

model Cantique {
  id        String   @id @default(cuid())
  title     String
  reference String
  category  String
  lyrics    Json
  chorus    Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  favorites FavoriteCantique[]

  @@map("cantiques")
}

model Evenement {
  id        String    @id @default(cuid())
  title     String
  content   String
  imageUrl  String?
  isActive  Boolean   @default(true)
  date      DateTime?
  location  String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("evenements")
}

model Sermon {
  id          String   @id @default(cuid())
  title       String
  content     String   @db.Text
  authorId    String
  author      User     @relation(fields: [authorId], references: [id])
  isShared    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  slides      Slide[]
  liveSessions LiveSession[]

  @@map("sermons")
}

model Slide {
  id        String   @id @default(cuid())
  sermonId  String
  sermon    Sermon   @relation(fields: [sermonId], references: [id], onDelete: Cascade)
  content   String   @db.Text
  type      String   @default("TEXT") // TEXT, VERSE, CITATION
  metadata  Json?    // { book, chapter, verse } or { name, paragraph, location, date, image }
  order     Int
  createdAt DateTime @default(now())

  @@map("slides")
}

model LiveSession {
  id             String   @id @default(cuid())
  sermonId       String
  sermon         Sermon   @relation(fields: [sermonId], references: [id])
  activeSlideId  String?
  isActive       Boolean  @default(true)
  startedAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("live_sessions")
}

model FavoriteVideo {
  id      String @id @default(cuid())
  userId  String
  videoId String

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  video Video @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@unique([userId, videoId])
  @@map("favorite_videos")
}

model Setting {
  id          String   @id @default("singleton")
  churchName  String   @default("Plénitude Tabernacle")
  description String   @db.Text
  address     String?
  phone       String?
  email       String?
  website     String?
  facebook    String?
  youtube     String?
  instagram   String?
  twitter     String?
  schedule    Json?    // Array of { day, time, title }
  updatedAt   DateTime @updatedAt

  @@map("settings")
}

model FavoriteAudio {
  id      String @id @default(cuid())
  userId  String
  audioId String

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  audio Audio @relation(fields: [audioId], references: [id], onDelete: Cascade)

  @@unique([userId, audioId])
  @@map("favorite_audios")
}

model FavoriteCantique {
  id         String @id @default(cuid())
  userId     String
  cantiqueId String

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  cantique Cantique @relation(fields: [cantiqueId], references: [id], onDelete: Cascade)

  @@unique([userId, cantiqueId])
  @@map("favorite_cantiques")
}
